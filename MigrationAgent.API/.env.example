# Copy this file to .env and fill in your Groq API keys
# Get keys from https://console.groq.com

# Supports multiple keys — rotated automatically on rate limits
GROQ_API_KEY_1=your_groq_api_key_here
GROQ_API_KEY_2=your_second_groq_api_key_here   # optional

# Model to use (optional — defaults to llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile
