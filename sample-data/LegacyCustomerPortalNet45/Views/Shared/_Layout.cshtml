<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Legacy Customer Portal</title>
    <link rel="stylesheet" href="@Url.Content("~/Content/Site.css")" />
</head>
<body>
    <header class="topbar">
        <div class="brand">Legacy Customer Portal</div>
        <nav>
            <a href="@Url.Action("Index", "Home")">Dashboard</a>
            <a href="/api/orders">Orders API</a>
        </nav>
    </header>
    <main class="page">
        @RenderBody()
    </main>
    <script src="@Url.Content("~/Scripts/portal.js")"></script>
</body>
</html>
